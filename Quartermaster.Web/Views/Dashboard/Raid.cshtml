@model Quartermaster.Core.Models.RaidSetting
@{
    var guild = ViewBag.Guild as Quartermaster.Web.Services.DiscordGuild;
    var incidents = ViewBag.Incidents as IEnumerable<dynamic> ?? new List<dynamic>(); // Simplify for now
    ViewData["Title"] = "Raid Protection - " + guild?.Name;
}

<div class="dashboard-container">
    <div class="container">
        <div class="breadcrumb">
            <a asp-action="Index">Dashboard</a> /
            <a href="/dashboard/server/@guild?.Id">@guild?.Name</a> /
            <span>Raid Protection</span>
        </div>

        <h1>🛡️ Raid Protection</h1>
        <p>Shield your server from automated raid attacks with intelligent join-rate monitoring.</p>

        <form id="raidForm">
            <!-- 1. General Settings -->
            <div class="settings-section">
                <h2>Configuration</h2>

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" name="enabled" checked="@(Model.Enabled == 1)">
                        <span class="toggle-slider"></span>
                        Enable Raid Protection
                    </label>
                    <small>Automatically detect and respond to sudden bursts of new members joining.</small>
                </div>

                <div class="form-row" style="display:flex; gap:20px;">
                    <div class="form-group" style="flex:1;">
                        <label>Join Threshold</label>
                        <input type="number" name="JoinThreshold" value="@Model.JoinThreshold" min="2" max="50" class="input-field">
                        <small>Number of members joining to trigger detection.</small>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>Time Window (seconds)</label>
                        <input type="number" name="TimeWindow" value="@Model.TimeWindow" min="5" max="300" class="input-field">
                        <small>The timeframe (in seconds) to count joins.</small>
                    </div>
                </div>

                <div class="form-group">
                    <label>Alert Channel</label>
                    <input type="text" name="AlertChannel" value="@Model.AlertChannel" class="input-field" placeholder="Channel Name (e.g. staff-chat)">
                    <small>Channel where the bot will post raid alerts.</small>
                </div>
            </div>

            <!-- 2. Automated Response -->
            <div class="settings-section">
                <h2>Automated Response</h2>

                <div class="form-group">
                    <label>Action on Raid Detection</label>
                    <select name="action" class="input-select">
                        <option value="alert" selected="@(Model.Action == "alert")">Alert Only (No Action)</option>
                        <option value="kick" selected="@(Model.Action == "kick")">Kick Raiders</option>
                        <option value="ban" selected="@(Model.Action == "ban")">Ban Raiders</option>
                        <option value="lockdown" selected="@(Model.Action == "lockdown")">Server Lockdown</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Lockdown Duration (seconds)</label>
                    <input type="number" name="LockdownDuration" value="@Model.LockdownDuration" min="60" max="3600" class="input-field">
                </div>
            </div>

            <div style="margin-top: 2rem;">
                <button type="submit" class="btn btn-primary btn-large">Save Raid Settings</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const guildId = '@guild?.Id';

        document.getElementById('raidForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const data = Object.fromEntries(formData.entries());
                data.Enabled = formData.get('enabled') === 'on' ? 1 : 0;
                delete data.enabled;

                const response = await fetch(`/api/server/${guildId}/raid`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                alert(result.success ? 'Raid protection settings updated!' : 'Error: ' + result.error);
            } catch (err) { alert('Network error: ' + err.message); }
        });
    </script>
}
