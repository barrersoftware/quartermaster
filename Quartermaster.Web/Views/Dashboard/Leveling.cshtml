@model Quartermaster.Core.Models.GuildSetting
@{
    var guild = ViewBag.Guild as Quartermaster.Web.Services.DiscordGuild;
    var channels = ViewBag.Channels as IEnumerable<Quartermaster.Web.Services.DiscordChannel> ?? new List<Quartermaster.Web.Services.DiscordChannel>();
    var roles = ViewBag.Roles as IEnumerable<Quartermaster.Web.Services.DiscordRole> ?? new List<Quartermaster.Web.Services.DiscordRole>();
    var roleRewards = ViewBag.RoleRewards as IEnumerable<Quartermaster.Core.Models.RoleReward> ?? new List<Quartermaster.Core.Models.RoleReward>();
    ViewData["Title"] = "Leveling - " + guild?.Name;
}

<div class="dashboard-container">
    <div class="container">
        <div class="breadcrumb">
            <a asp-action="Index">Dashboard</a> /
            <a href="/dashboard/server/@guild?.Id">@guild?.Name</a> /
            <span>Leveling</span>
        </div>

        <h1>Leveling Settings</h1>

        <div class="settings-section">
            <h2>General Settings</h2>
            <form id="levelingForm">
                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" name="enabled" @(Model.LevelingEnabled == 1 ? "checked" : "")>
                        <span class="toggle-slider"></span>
                        Enable Leveling System
                    </label>
                </div>

                <div class="form-group">
                    <label>Level Up Message</label>
                    <input type="text" name="levelUpMessage" value="@(Model.LevelUpMessage ?? "Congratulations {user}, you just advanced to level {level}!")" class="input-field">
                    <small>Use {user} for mention and {level} for the new level.</small>
                </div>

                <button type="submit" class="btn btn-primary">Save Settings</button>
            </form>
        </div>

        <div class="settings-section">
            <h2>Level Up Announcements</h2>
            <form id="announcementForm">
                <div class="form-group">
                    <label>Announcement Channel</label>
                    <select name="LevelUpChannel" class="input-select">
                        <option value="disabled" selected="@(Model.LevelUpChannel == "disabled" ? "selected" : null)">🚫 Disabled (No Announcement)</option>
                        <option value="" selected="@(string.IsNullOrEmpty(Model.LevelUpChannel) ? "selected" : null)">In the channel where it happened</option>
                        @foreach (var channel in channels)
                        {
                            <option value="@channel.Id" selected="@(Model.LevelUpChannel == channel.Id ? "selected" : null)">#@channel.Name</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Save Announcement Settings</button>
            </form>
        </div>

        <div class="settings-section">
            <h2>Role Rewards</h2>
            <table class="table">
                <thead>
                    <tr>
                        <th>Level</th>
                        <th>Role ID</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!roleRewards.Any())
                    {
                        <tr><td colspan="3" class="muted">No role rewards configured yet.</td></tr>
                    }
                    else
                    {
                        foreach (var reward in roleRewards)
                        {
                            <tr>
                                <td><strong>@reward.Level</strong></td>
                                <td><code>@reward.RoleId</code></td>
                                <td><button type="button" class="btn btn-small btn-danger" onclick="deleteRoleReward(@reward.Level)">Delete</button></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <form id="roleRewardForm" style="margin-top: 1rem; display:grid; grid-template-columns: 1fr 2fr auto; gap: 12px; align-items:end;">
                <div class="form-group">
                    <label>Level</label>
                    <input type="number" name="level" class="input-field" min="1" required>
                </div>
                <div class="form-group">
                    <label>Role</label>
                    <select name="roleId" class="input-select" required>
                        <option value="">Select a role</option>
                        @foreach (var role in roles)
                        {
                            <option value="@role.Id">@role.Name</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Add Reward</button>
            </form>
        </div>

        <div class="settings-section">
            <h2>Visual Customization</h2>
            <form id="visualForm">
                <div class="form-group">
                    <label>Progress Bar Color</label>
                    <div class="color-picker-group" style="display:flex; gap:10px;">
                        <input type="color" name="RankCardColor" value="@Model.RankCardColor" class="color-input">
                        <input type="text" id="colorText" value="@Model.RankCardColor" class="input-field" style="width: 100px;">
                    </div>
                </div>
                <div class="form-group">
                    <label>Custom Rank Card Background (URL)</label>
                    <input type="text" name="RankBackground" value="@Model.RankBackground" class="input-field" placeholder="https://example.com/image.png">
                </div>
                <button type="submit" class="btn btn-primary">Update Visuals</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const guildId = '@guild?.Id';

        document.getElementById('levelingForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const response = await fetch(`/api/server/${guildId}/settings/leveling`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        enabled: formData.get('enabled') === 'on',
                        levelUpMessage: formData.get('levelUpMessage')
                    })
                });
                const data = await response.json();
                alert(data.success ? 'Leveling settings saved!' : 'Error saving settings');
            } catch (err) { alert('Network error: ' + err.message); }
        });

        document.getElementById('announcementForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const response = await fetch(`/api/server/${guildId}/settings/leveling`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        updateChannel: true,
                        levelUpChannel: formData.get('LevelUpChannel') || ""
                    })
                });
                const data = await response.json();
                alert(data.success ? 'Announcement settings saved!' : 'Error saving settings');
            } catch (err) { alert('Network error: ' + err.message); }
        });

        document.getElementById('roleRewardForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const response = await fetch(`/api/server/${guildId}/leveling/role-rewards`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        level: Number(formData.get('level')),
                        roleId: formData.get('roleId')
                    })
                });
                const data = await response.json();
                if (data.success) location.reload();
                else alert(data.error || 'Failed to add role reward.');
            } catch (err) { alert('Network error: ' + err.message); }
        });

        async function deleteRoleReward(level) {
            if (!confirm(`Delete the role reward for level ${level}?`)) return;
            try {
                const response = await fetch(`/api/server/${guildId}/leveling/role-rewards/${level}`, {
                    method: 'DELETE'
                });
                const data = await response.json();
                if (data.success) location.reload();
                else alert(data.error || 'Failed to delete role reward.');
            } catch (err) { alert('Network error: ' + err.message); }
        }

        document.getElementById('visualForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const response = await fetch(`/api/server/${guildId}/settings/visuals`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.fromEntries(formData.entries()))
                });
                const data = await response.json();
                alert(data.success ? 'Visuals updated!' : 'Update failed');
            } catch (err) { alert('Network error: ' + err.message); }
        });

        // Sync visual color picker and text hex value input
        const colorInput = document.querySelector('input[name="RankCardColor"]');
        const colorText = document.getElementById('colorText');
        if (colorInput && colorText) {
            colorInput.addEventListener('input', (e) => {
                colorText.value = e.target.value;
            });
            colorText.addEventListener('input', (e) => {
                const val = e.target.value.trim();
                if (/^#[0-9A-F]{6}$/i.test(val)) {
                    colorInput.value = val;
                }
            });
        }
    </script>
}
