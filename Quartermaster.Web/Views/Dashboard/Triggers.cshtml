@model IEnumerable<Quartermaster.Core.Models.AdvancedTrigger>
@{
    var guild = ViewBag.Guild as Quartermaster.Web.Services.DiscordGuild;
    ViewData["Title"] = "Triggers - " + guild?.Name;
}

<div class="dashboard-container">
    <div class="container">
        <div class="breadcrumb">
            <a asp-action="Index">Dashboard</a> /
            <a href="/dashboard/server/@guild?.Id">@guild?.Name</a> /
            <span>Advanced Triggers</span>
        </div>

        <h1>Advanced Triggers</h1>
        <p>Define automated responses when members type specific phrases (no prefix required).</p>

        <div class="settings-section">
            <h2>Active Triggers</h2>
            <table class="table">
                <thead>
                    <tr>
                        <th>Phrase</th>
                        <th>Response</th>
                        <th>Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="muted">No triggers configured.</td></tr>
                    }
                    else
                    {
                        foreach (var trigger in Model)
                        {
                            <tr>
                                <td><code>@trigger.TriggerPhrase</code></td>
                                <td><div style="max-width:300px; overflow:hidden; text-overflow:ellipsis;">@trigger.Response</div></td>
                                <td><span class="badge @(trigger.Type == "embed" ? "badge-info" : "badge-secondary")">@trigger.Type.ToUpper()</span></td>
                                <td>
                                    <button class="btn btn-small btn-danger" onclick="deleteTrigger('@trigger.TriggerPhrase')">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="add-box" style="margin-top: 2rem; padding: 25px; background: rgba(0,0,0,0.1); border-radius: 8px;">
                <h3>Add New Trigger</h3>
                <form id="addTriggerForm" style="margin-top: 15px;">
                    <div class="form-group">
                        <label>Trigger Phrase</label>
                        <input type="text" name="TriggerPhrase" class="input-field" placeholder="e.g. how to join" required>
                    </div>
                    <div class="form-group">
                        <label>Response Content</label>
                        <textarea name="Response" rows="3" class="input-field" required></textarea>
                    </div>
                    <div class="form-group">
                        <label>Response Type</label>
                        <select name="Type" class="input-select">
                            <option value="text">Plain Text</option>
                            <option value="embed">Rich Embed</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Create Trigger</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const guildId = '@guild?.Id';

        document.getElementById('addTriggerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const response = await fetch(`/api/server/${guildId}/triggers`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.fromEntries(formData.entries()))
                });
                if (response.ok) location.reload();
                else alert('Failed to create trigger: ' + response.statusText);
            } catch (err) { alert('Network error: ' + err.message); }
        });

        async function deleteTrigger(phrase) {
            if (!confirm(`Delete trigger for "${phrase}"?`)) return;
            try {
                const response = await fetch(`/api/server/${guildId}/triggers/${encodeURIComponent(phrase)}`, {
                    method: 'DELETE'
                });
                if (response.ok) location.reload();
            } catch (err) { alert('Network error: ' + err.message); }
        }
    </script>
}
