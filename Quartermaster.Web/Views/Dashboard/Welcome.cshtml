@model Quartermaster.Core.Models.GuildSetting
@{
    var guild = ViewBag.Guild as Quartermaster.Web.Services.DiscordGuild;
    var channels = ViewBag.Channels as IEnumerable<Quartermaster.Web.Services.DiscordChannel> ?? new List<Quartermaster.Web.Services.DiscordChannel>();
    var roles = ViewBag.Roles as IEnumerable<Quartermaster.Web.Services.DiscordRole> ?? new List<Quartermaster.Web.Services.DiscordRole>();
    ViewData["Title"] = "Welcome - " + guild?.Name;
}

<div class="dashboard-container">
    <div class="container">
        <div class="breadcrumb">
            <a asp-action="Index">Dashboard</a> /
            <a href="/dashboard/server/@guild?.Id">@guild?.Name</a> /
            <span>Welcome & Leave</span>
        </div>

        <h1>Welcome & Leave Messages</h1>
        <p>Configure automated messages and roles for new and departing members.</p>

        <form id="welcomeForm">
            <div class="settings-section">
                <h2>Welcome Configuration</h2>

                <div class="form-group">
                    <label>Auto-Role (Join Role)</label>
                    <select name="auto_role" class="input-select">
                        <option value="">None (Disabled)</option>
                        @foreach (var role in roles)
                        {
                            var isSelected = Model.AutoRole == role.Id;
                            <option value="@role.Id" selected="@isSelected">@role.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Welcome Channel</label>
                    <select name="welcomeChannel" class="input-select">
                        <option value="">Disabled</option>
                        @foreach (var channel in channels)
                        {
                            var isSelected = Model.WelcomeChannel == channel.Id;
                            <option value="@channel.Id" selected="@isSelected">#@channel.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Welcome Message</label>
                    <input type="text" name="welcome_message" value="@(Model.WelcomeMessage ?? "Welcome {user} to {server}!")" class="input-field">
                    <small>Use {user}, {server}, and {memberCount} in your message.</small>
                </div>

                <div class="form-group">
                    <label>Custom Welcome Card Background (URL)</label>
                    <input type="text" name="welcome_background" value="@Model.WelcomeBackground" class="input-field" placeholder="https://example.com/welcome-bg.png">
                </div>
            </div>

            <div class="settings-section">
                <h2>Leave Messages</h2>

                <div class="form-group">
                    <label>Leave Channel</label>
                    <select name="leave_channel" class="input-select">
                        <option value="">Disabled</option>
                        @foreach (var channel in channels)
                        {
                            var isSelected = Model.LeaveChannel == channel.Id;
                            <option value="@channel.Id" selected="@isSelected">#@channel.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Leave Message</label>
                    <input type="text" name="leave_message" value="@(Model.LeaveMessage ?? "{user} has left the server. We now have {memberCount} members.")" class="input-field">
                    <small>Use {user}, {server}, and {memberCount} in your message.</small>
                </div>
            </div>

            <div style="margin-top: 2rem;">
                <button type="submit" class="btn btn-primary btn-large">Save Welcome & Leave Settings</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const guildId = '@guild?.Id';

        document.getElementById('welcomeForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
                const formData = new FormData(e.target);
                const payload = Object.fromEntries(formData.entries());
                const welcomeResponse = await fetch(`/api/server/${guildId}/welcome`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const welcomeData = await welcomeResponse.json();
                if (!welcomeData.success) {
                    alert(welcomeData.error || 'Failed to save welcome settings.');
                    return;
                }

                const leaveResponse = await fetch(`/api/server/${guildId}/welcome/leave`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        leaveChannel: payload.leave_channel || null,
                        leaveMessage: payload.leave_message || null
                    })
                });
                const leaveData = await leaveResponse.json();
                alert(leaveData.success ? 'Settings saved!' : (leaveData.error || 'Failed to save leave settings.'));
            } catch (err) {
                alert('Network error: ' + err.message);
            }
        });
    </script>
}
