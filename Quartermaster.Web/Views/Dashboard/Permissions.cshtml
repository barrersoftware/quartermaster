@model Quartermaster.Core.Models.GuildSetting
@{
    var guild = ViewBag.Guild as Quartermaster.Web.Services.DiscordGuild;
    var roles = ViewBag.Roles as IEnumerable<dynamic> ?? new List<dynamic>();
    var modRoles = Model.ModRoles != null ? System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.ModRoles) : new List<string>();
    ViewData["Title"] = "Permissions - " + guild?.Name;
}

<div class="dashboard-container">
    <div class="container">
        <div class="breadcrumb">
            <a asp-action="Index">Dashboard</a> /
            <a href="/dashboard/server/@guild?.Id">@guild?.Name</a> /
            <span>Permissions</span>
        </div>

        <h1>Role-Based Access Control (RBAC)</h1>
        <p>Define specific roles that are authorized to perform moderator actions and manage bot settings.</p>

        <div class="settings-section">
            <h2>Moderator Roles</h2>
            <div class="info-box" style="margin-bottom: 20px;">
                <strong>Note:</strong> Server Administrators always have full access to all bot features.
            </div>

            <div class="roles-manager">
                <div class="active-roles" style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px;">
                    @if (!modRoles.Any())
                    {
                        <p class="muted">No moderator roles designated.</p>
                    }
                    else
                    {
                        foreach (var roleId in modRoles)
                        {
                            var role = roles.FirstOrDefault(r => r.id == roleId);
                            <div class="role-tag" style="background: var(--bg-tertiary); padding: 8px 15px; border-radius: 6px; display: flex; align-items: center; gap: 10px;">
                                <span style="font-weight: 600;">@@@(role?.name ?? roleId)</span>
                                <button onclick="removeRole('@roleId')" class="remove-role" style="background: none; border: none; color: var(--danger-color); cursor: pointer; font-size: 1.2rem;">&times;</button>
                            </div>
                        }
                    }
                </div>

                <div class="add-box" style="padding: 20px; background: rgba(0,0,0,0.1); border-radius: 8px;">
                    <h3>Designate New Moderator Role</h3>
                    <div style="display:flex; gap:10px; margin-top:10px;">
                        <select id="role-select" class="input-select" style="max-width: 300px;">
                            <option value="">Select a role...</option>
                            @foreach (var role in roles)
                            {
                                if (!modRoles.Contains(role.id))
                                {
                                    <option value="@role.id">@@@role.name</option>
                                }
                            }
                        </select>
                        <button onclick="addRole()" class="btn btn-primary">Grant Access</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const guildId = '@guild?.Id';

        async function addRole() {
            const roleId = document.getElementById('role-select').value;
            if (!roleId) return;

            const response = await fetch(`/api/server/${guildId}/permissions/mod-roles`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roleId })
            });
            if (response.ok) location.reload();
        }

        async function removeRole(roleId) {
            if (!confirm('Remove this role from moderators?')) return;
            const response = await fetch(`/api/server/${guildId}/permissions/mod-roles/${roleId}`, {
                method: 'DELETE'
            });
            if (response.ok) location.reload();
        }
    </script>
}
