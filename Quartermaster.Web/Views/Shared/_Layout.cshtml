<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quartermaster</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.png" alt="Quartermaster Logo" class="nav-logo" />
                    <span>Quartermaster</span>
                </a>
            </div>
            <div class="nav-menu">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    <div class="user-info">
                        <img src="@User.FindFirst("urn:discord:avatar")?.Value" class="user-avatar-small" />
                        <span class="username">@User.Identity.Name</span>
                        <a href="/logout" class="btn btn-outline">Logout</a>
                    </div>
                }
                else
                {
                    <a href="/login" class="btn btn-primary">Login</a>
                }
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Quartermaster .NET • Built for the g4turbo Community</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Automatically attach XSRF token to all non-GET fetch requests
        (function () {
            const _fetch = window.fetch;
            window.fetch = async function (url, opts = {}) {
                if (opts.method && opts.method.toUpperCase() !== 'GET') {
                    const token = document.cookie.split('; ')
                        .find(r => r.startsWith('XSRF-TOKEN='))?.split('=')[1];
                    if (token) {
                        opts.headers = Object.assign({}, opts.headers, {
                            'X-XSRF-TOKEN': decodeURIComponent(token)
                        });
                    }
                }
                return _fetch(url, opts);
            };
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
