<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Triggers - <%= guild.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="dashboard-container">
        <div class="container">
            <div class="breadcrumb">
                <a href="/dashboard">Dashboard</a> /
                <a href="/dashboard/server/<%= guild.id %>"><%= guild.name %></a> /
                <span>Advanced Triggers</span>
            </div>

            <h1>Advanced Triggers</h1>
            <p>Define automated responses when members type specific phrases (no prefix required).</p>

            <div class="settings-section">
                <h2>Active Triggers</h2>
                
                <div class="triggers-list">
                    <% if (triggers.length === 0) { %>
                        <p class="muted">No advanced triggers configured.</p>
                    <% } else { %>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Trigger Phrase</th>
                                    <th>Response</th>
                                    <th>Type</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% triggers.forEach(trigger => { %>
                                    <tr>
                                        <td><code><%= trigger.trigger_phrase %></code></td>
                                        <td><div class="truncate" style="max-width: 300px;"><%= trigger.response %></div></td>
                                        <td><span class="badge <%= trigger.type === 'embed' ? 'badge-info' : 'badge-secondary' %>"><%= trigger.type.toUpperCase() %></span></td>
                                        <td>
                                            <button class="btn btn-small btn-danger" onclick="deleteTrigger('<%= trigger.trigger_phrase %>')">Delete</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>
                </div>

                <div class="add-box" style="margin-top: 2rem; padding: 25px; background: rgba(0,0,0,0.1); border-radius: 8px;">
                    <h3>Add New Trigger</h3>
                    <form id="addTriggerForm" style="margin-top: 15px;">
                        <div class="form-group">
                            <label>Trigger Phrase (Keywords)</label>
                            <input type="text" name="phrase" class="input-field" placeholder="e.g. how to join" required>
                        </div>
                        <div class="form-group">
                            <label>Response Content</label>
                            <textarea name="response" rows="3" class="input-field" placeholder="What should the bot say?" required></textarea>
                        </div>
                        <div class="form-group">
                            <label>Response Type</label>
                            <select name="type" class="input-select">
                                <option value="text">Plain Text</option>
                                <option value="embed">Rich Embed</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Create Trigger</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div id="notification" class="notification"></div>

    <%- include('../partials/footer') %>

    <script>
        const guildId = '<%= guild.id %>';

        document.getElementById('addTriggerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                const response = await fetch(`/api/server/${guildId}/triggers`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (result.success) location.reload();
                else showNotification(result.error, 'error');
            } catch (e) {
                console.error(e);
                showNotification('Failed to create trigger', 'error');
            }
        });

        async function deleteTrigger(phrase) {
            if (!confirm(`Delete trigger for "${phrase}"?`)) return;

            try {
                const response = await fetch(`/api/server/${guildId}/triggers/${encodeURIComponent(phrase)}`, {
                    method: 'DELETE'
                });
                const result = await response.json();
                if (result.success) location.reload();
                else showNotification(result.error, 'error');
            } catch (e) {
                console.error(e);
                showNotification('Failed to remove trigger', 'error');
            }
        }

        function showNotification(message, type) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification notification-${type} show`;
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    </script>
</body>
</html>
