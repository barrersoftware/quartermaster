<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Embed Builder - <%= guild.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="dashboard-container">
        <div class="container">
            <div class="breadcrumb">
                <a href="/dashboard">Dashboard</a> /
                <a href="/dashboard/server/<%= guild.id %>"><%= guild.name %></a> /
                <span>Embed Builder</span>
            </div>

            <h1>Visual Embed Builder</h1>
            <p>Design a beautiful announcement and send it directly to your server.</p>

            <div class="settings-grid">
                <!-- 1. Editor -->
                <div class="settings-section">
                    <h2>Design Editor</h2>
                    <form id="embedForm">
                        <div class="form-group">
                            <label>Target Channel</label>
                            <select name="channelId" class="input-select" required>
                                <% channels.forEach(ch => { %>
                                    <option value="<%= ch.id %>">#<%= ch.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Title</label>
                            <input type="text" id="ebTitle" name="title" class="input-field" placeholder="Embed Title">
                        </div>
                        <div class="form-group">
                            <label>Description (Markdown supported)</label>
                            <textarea id="ebDesc" name="description" rows="5" class="input-field" placeholder="Your main message content..." required></textarea>
                        </div>
                        <div class="form-group">
                            <label>Color</label>
                            <input type="color" id="ebColor" name="color" value="#5865F2" class="input-color">
                        </div>
                        <div class="form-group">
                            <label>Image URL</label>
                            <input type="text" id="ebImage" name="image" class="input-field" placeholder="https://example.com/hero.png">
                        </div>
                        <div class="form-group">
                            <label>Thumbnail URL</label>
                            <input type="text" id="ebThumb" name="thumbnail" class="input-field" placeholder="https://example.com/icon.png">
                        </div>
                        <div class="form-group">
                            <label>Footer Text</label>
                            <input type="text" id="ebFooter" name="footer" class="input-field" placeholder="Small text at the bottom">
                        </div>
                        <button type="submit" class="btn btn-primary btn-large" style="width: 100%;">Send Embed to Discord</button>
                    </form>
                </div>

                <!-- 2. Preview -->
                <div class="settings-section">
                    <h2>Live Preview</h2>
                    <div id="embedPreview" class="discord-embed-preview" style="border-left-color: #5865F2; background: #2f3136; border-radius: 4px; border-left-width: 4px; padding: 15px; display: flex; gap: 15px;">
                        <div class="preview-content" style="flex: 1;">
                            <div id="previewTitle" class="preview-title" style="font-weight: 700; font-size: 1rem; margin-bottom: 8px;">Title Preview</div>
                            <div id="previewDesc" class="preview-description" style="font-size: 0.9rem; white-space: pre-wrap;">Description will appear here...</div>
                            <img id="previewImage" src="" class="preview-image hidden" style="width: 100%; border-radius: 4px; margin-top: 10px; max-height: 300px; object-fit: cover;">
                            <div id="previewFooter" class="preview-footer" style="font-size: 0.75rem; color: #b9bbbe; margin-top: 10px;">Footer text</div>
                        </div>
                        <img id="previewThumb" src="" class="preview-thumbnail hidden" style="width: 80px; height: 80px; border-radius: 4px; object-fit: cover;">
                    </div>
                    <div class="info-box" style="margin-top: 20px;">
                        <small>Markdown and mentions are simulated. Images will only appear if the URL is valid and publicly accessible.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="notification" class="notification"></div>

    <%- include('../partials/footer') %>

    <script>
        const guildId = '<%= guild.id %>';

        // Live Preview Logic
        const inputs = ['ebTitle', 'ebDesc', 'ebColor', 'ebImage', 'ebThumb', 'ebFooter'];
        const previewMap = {
            'ebTitle': 'previewTitle',
            'ebDesc': 'previewDesc',
            'ebFooter': 'previewFooter'
        };

        function updatePreview() {
            for (const [inputId, previewId] of Object.entries(previewMap)) {
                document.getElementById(previewId).textContent = document.getElementById(inputId).value || (inputId === 'ebTitle' ? '' : '...');
            }

            document.getElementById('embedPreview').style.borderLeftColor = document.getElementById('ebColor').value;

            const imgUrl = document.getElementById('ebImage').value;
            const thumbUrl = document.getElementById('ebThumb').value;
            
            const previewImg = document.getElementById('previewImage');
            if (imgUrl) { previewImg.src = imgUrl; previewImg.classList.remove('hidden'); }
            else { previewImg.classList.add('hidden'); }

            const previewThumb = document.getElementById('previewThumb');
            if (thumbUrl) { previewThumb.src = thumbUrl; previewThumb.classList.remove('hidden'); }
            else { previewThumb.classList.add('hidden'); }
        }

        inputs.forEach(id => document.getElementById(id).addEventListener('input', updatePreview));

        document.getElementById('embedForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            if (!confirm(`Are you sure you want to send this embed to the selected channel?`)) return;

            try {
                const response = await fetch(`/api/server/${guildId}/embed/send`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                showNotification(result.success ? 'Embed sent successfully!' : 'Error: ' + result.error, result.success ? 'success' : 'error');
            } catch (e) {
                console.error(e);
                showNotification('Failed to send embed', 'error');
            }
        });

        function showNotification(message, type) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification notification-${type} show`;
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    </script>
</body>
</html>
