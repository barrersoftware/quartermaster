<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moderation - <%= guild.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="dashboard-container">
        <div class="container">
            <div class="breadcrumb">
                <a href="/dashboard">Dashboard</a> /
                <a href="/dashboard/server/<%= guild.id %>"><%= guild.name %></a> /
                <span>Moderation</span>
            </div>

            <h1>Moderation & Auto-Mod</h1>
            <p>Maintain server order with automated protections and a searchable warning history.</p>

            <div class="settings-grid">
                <!-- 1. Auto-Moderation Toggles -->
                <div class="settings-section">
                    <h2>Auto-Moderation</h2>
                    <form id="automod-form">
                        <div class="setting-item">
                            <label>General Spam Protection</label>
                            <select name="spam_enabled" class="input-select">
                                <option value="1" <%= automod.spam_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.spam_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Spam Threshold (messages/5s)</label>
                            <input type="number" name="spam_threshold" value="<%= automod.spam_threshold %>" class="input-field">
                        </div>
                        <div class="setting-item">
                            <label>Link Filtering</label>
                            <select name="links_enabled" class="input-select">
                                <option value="1" <%= automod.links_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.links_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Invite Filtering</label>
                            <select name="invites_enabled" class="input-select">
                                <option value="1" <%= automod.invites_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.invites_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Bad Words Filter</label>
                            <select name="badwords_enabled" class="input-select">
                                <option value="1" <%= automod.badwords_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.badwords_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Emoji Spam Protection</label>
                            <select name="emoji_spam_enabled" class="input-select">
                                <option value="1" <%= automod.emoji_spam_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.emoji_spam_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Emoji Threshold (Max emojis)</label>
                            <input type="number" name="emoji_threshold" value="<%= automod.emoji_threshold %>" class="input-field">
                        </div>
                        <div class="setting-item">
                            <label>Caps Spam Protection</label>
                            <select name="caps_spam_enabled" class="input-select">
                                <option value="1" <%= automod.caps_spam_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.caps_spam_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Caps Threshold (%)</label>
                            <input type="number" name="caps_threshold" value="<%= automod.caps_threshold %>" class="input-field" min="1" max="100">
                        </div>
                        <div class="setting-item">
                            <label>Mention Spam Protection</label>
                            <select name="mention_spam_enabled" class="input-select">
                                <option value="1" <%= automod.mention_spam_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.mention_spam_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Mention Threshold (Max pings)</label>
                            <input type="number" name="mention_threshold" value="<%= automod.mention_threshold %>" class="input-field">
                        </div>
                        <button type="submit" class="btn btn-primary btn-large" style="width: 100%; margin-top: 1rem;">Save Protections</button>
                    </form>
                </div>

                <!-- 2. Word Blacklist -->
                <div class="settings-section">
                    <h2>Forbidden Words</h2>
                    <p>Messages containing these words will be automatically deleted if Bad Words Filter is enabled.</p>
                    <div class="add-box" style="margin-bottom: 20px; padding: 15px; background: rgba(0,0,0,0.1); border-radius: 8px;">
                        <div class="form-row">
                            <input type="text" id="new-word" placeholder="Add word to block..." class="input-field">
                            <button id="add-word-btn" class="btn btn-secondary">Add Word</button>
                        </div>
                    </div>
                    <div class="word-list" style="display: flex; flex-wrap: wrap; gap: 8px;">
                        <% if (blacklist.length === 0) { %>
                            <p class="muted">Blacklist is empty.</p>
                        <% } else { %>
                            <% blacklist.forEach(item => { %>
                                <span class="word-tag" style="background: var(--bg-tertiary); padding: 5px 12px; border-radius: 20px; border: 1px solid var(--border-color); display: flex; align-items: center; gap: 8px;">
                                    <code><%= item.word %></code>
                                    <button class="remove-word" onclick="removeWord('<%= item.word %>')" style="background: none; border: none; color: var(--danger-color); cursor: pointer; font-size: 1.2rem; line-height: 1;">&times;</button>
                                </span>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- 3. Warning History -->
            <div class="settings-section">
                <h2>Warning History</h2>
                <% if (warnings.length === 0) { %>
                    <p class="muted">No warnings have been issued yet.</p>
                <% } else { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Reason</th>
                                <th>Moderator</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% warnings.forEach(warning => { %>
                                <tr>
                                    <td><code><%= warning.user_id %></code></td>
                                    <td><%= warning.reason || 'No reason provided' %></td>
                                    <td><code><%= warning.moderator_id %></code></td>
                                    <td class="muted"><%= new Date(warning.timestamp * 1000).toLocaleString() %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>

            <!-- 4. Quick Commands -->
            <div class="settings-section">
                <h2>Moderation Commands</h2>
                <div class="info-box">
                    <p>These commands can be used directly in Discord by staff members:</p>
                    <table class="table table-small" style="margin-top: 10px;">
                        <tbody>
                            <tr><td><code>/ban</code></td><td>Ban a member permanently</td></tr>
                            <tr><td><code>/kick</code></td><td>Remove a member from the server</td></tr>
                            <tr><td><code>/mute</code></td><td>Temporary timeout for a member</td></tr>
                            <tr><td><code>/warn</code></td><td>Issue a formal warning</td></tr>
                            <tr><td><code>/warnings</code></td><td>View a member's warning history</td></tr>
                            <tr><td><code>/clearwarnings</code></td><td>Wipe warnings for a member (Admin)</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div id="notification" class="notification"></div>

    <%- include('../partials/footer') %>

    <script>
        const guildId = '<%= guild.id %>';

        // Handle Auto-mod form
        document.getElementById('automod-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            
            try {
                const response = await fetch(`/api/server/${guildId}/automod`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                showNotification(result.success ? 'Auto-mod settings saved!' : 'Error: ' + result.error, result.success ? 'success' : 'error');
            } catch (error) {
                console.error(error);
                showNotification('Failed to save settings', 'error');
            }
        });

        // Handle Blacklist
        document.getElementById('add-word-btn').addEventListener('click', async () => {
            const wordInput = document.getElementById('new-word');
            const word = wordInput.value.trim();
            if (!word) return;

            try {
                const response = await fetch(`/api/server/${guildId}/automod/blacklist`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ word })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else showNotification('Error: ' + result.error, 'error');
            } catch (error) {
                console.error(error);
                showNotification('Failed to add word', 'error');
            }
        });

        async function removeWord(word) {
            if (!confirm(`Remove "${word}" from the blacklist?`)) return;

            try {
                const response = await fetch(`/api/server/${guildId}/automod/blacklist/${encodeURIComponent(word)}`, {
                    method: 'DELETE'
                });
                const result = await response.json();
                if (result.success) location.reload();
                else showNotification('Error: ' + result.error, 'error');
            } catch (error) {
                console.error(error);
                showNotification('Failed to remove word', 'error');
            }
        }

        function showNotification(message, type) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification notification-${type} show`;
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    </script>
</body>
</html>
