<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moderation - <%= guild.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="dashboard-container">
        <div class="container">
            <div class="breadcrumb">
                <a href="/dashboard">Dashboard</a> /
                <a href="/dashboard/server/<%= guild.id %>"><%= guild.name %></a> /
                <span>Moderation</span>
            </div>

            <h1>Moderation & Auto-Mod</h1>

            <div class="settings-grid">
                <div class="settings-section">
                    <h2>Auto-Moderation</h2>
                    <form id="automod-form">
                        <div class="setting-item">
                            <label>Spam Protection</label>
                            <select name="spam_enabled" class="input-select">
                                <option value="1" <%= automod.spam_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.spam_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Spam Threshold (messages/5s)</label>
                            <input type="number" name="spam_threshold" value="<%= automod.spam_threshold %>" class="input-field">
                        </div>
                        <div class="setting-item">
                            <label>Link Filtering</label>
                            <select name="links_enabled" class="input-select">
                                <option value="1" <%= automod.links_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.links_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Invite Filtering</label>
                            <select name="invites_enabled" class="input-select">
                                <option value="1" <%= automod.invites_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.invites_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label>Bad Words Filter</label>
                            <select name="badwords_enabled" class="input-select">
                                <option value="1" <%= automod.badwords_enabled ? 'selected' : '' %>>Enabled</option>
                                <option value="0" <%= !automod.badwords_enabled ? 'selected' : '' %>>Disabled</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Save Auto-Mod Settings</button>
                    </form>
                </div>

                <div class="settings-section">
                    <h2>Forbidden Words</h2>
                    <div class="blacklist-manager">
                        <div class="add-word">
                            <input type="text" id="new-word" placeholder="Add word to block..." class="input-field">
                            <button id="add-word-btn" class="btn btn-secondary">Add</button>
                        </div>
                        <div class="word-list">
                            <% if (blacklist.length === 0) { %>
                                <p class="muted">Blacklist is empty.</p>
                            <% } else { %>
                                <% blacklist.forEach(item => { %>
                                    <span class="word-tag">
                                        <%= item.word %>
                                        <button class="remove-word" onclick="removeWord('<%= item.word %>')">&times;</button>
                                    </span>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h2>Warning History</h2>

                <% if (warnings.length === 0) { %>
                    <div class="empty-state">
                        <p>No warnings have been issued yet.</p>
                    </div>
                <% } else { %>
                    <div class="warnings-table">
                        <table>
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Reason</th>
                                    <th>Moderator</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% warnings.forEach(warning => {
                                    const member = guild.members.cache.get(warning.user_id);
                                    const moderator = guild.members.cache.get(warning.moderator_id);
                                %>
                                    <tr>
                                        <td>
                                            <% if (member) { %>
                                                <%= member.user.tag %>
                                            <% } else { %>
                                                User ID: <%= warning.user_id %>
                                            <% } %>
                                        </td>
                                        <td><%= warning.reason || 'No reason provided' %></td>
                                        <td>
                                            <% if (moderator) { %>
                                                <%= moderator.user.tag %>
                                            <% } else { %>
                                                User ID: <%= warning.moderator_id %>
                                            <% } %>
                                        </td>
                                        <td><%= new Date(warning.timestamp * 1000).toLocaleString() %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>

            <div class="info-box">
                <h3>Moderation Commands</h3>
                <p>Use these commands in Discord to moderate your server:</p>
                <ul>
                    <li><code>!ban @user [reason]</code> - Ban a member</li>
                    <li><code>!kick @user [reason]</code> - Kick a member</li>
                    <li><code>!mute @user &lt;minutes&gt; [reason]</code> - Mute a member</li>
                    <li><code>!warn @user &lt;reason&gt;</code> - Warn a member</li>
                    <li><code>!warnings @user</code> - View warnings for a member</li>
                    <li><code>!clearwarnings @user</code> - Clear all warnings (Admin only)</li>
                </ul>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        // Handle Auto-mod form
        document.getElementById('automod-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            
            try {
                const response = await fetch(`/api/server/<%= guild.id %>/automod`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (result.success) {
                    alert('Auto-mod settings saved successfully!');
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                console.error(error);
                alert('Failed to save settings');
            }
        });

        // Handle Blacklist
        document.getElementById('add-word-btn').addEventListener('click', async () => {
            const wordInput = document.getElementById('new-word');
            const word = wordInput.value.trim();
            if (!word) return;

            try {
                const response = await fetch(`/api/server/<%= guild.id %>/automod/blacklist`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ word })
                });
                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                console.error(error);
                alert('Failed to add word');
            }
        });

        async function removeWord(word) {
            if (!confirm(`Remove "${word}" from the blacklist?`)) return;

            try {
                const response = await fetch(`/api/server/<%= guild.id %>/automod/blacklist/${encodeURIComponent(word)}`, {
                    method: 'DELETE'
                });
                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                console.error(error);
                alert('Failed to remove word');
            }
        }
    </script>
</body>
</html>
