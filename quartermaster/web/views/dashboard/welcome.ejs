<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome & Leave - <%= guild.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="dashboard-container">
        <div class="container">
            <div class="breadcrumb">
                <a href="/dashboard">Dashboard</a> /
                <a href="/dashboard/server/<%= guild.id %>"><%= guild.name %></a> /
                <span>Welcome & Leave</span>
            </div>

            <h1>Welcome & Leave Messages</h1>
            <p>Configure automated messages and roles for new and departing members.</p>

            <form id="welcomeForm">
                <!-- 1. Welcome Settings -->
                <div class="settings-section">
                    <h2>Welcome Configuration</h2>

                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" name="welcomeEnabled" <%= config.welcome.enabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            Enable Welcome Messages
                        </label>
                    </div>

                    <div class="form-group">
                        <label>Auto-Role (Join Role)</label>
                        <select name="auto_role" class="input-select">
                            <option value="">None (Disabled)</option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>" <%= settings.auto_role === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }); %>
                        </select>
                        <small>Role given automatically when a member joins.</small>
                    </div>

                    <div class="form-group">
                        <label>Welcome Channel</label>
                        <select name="welcomeChannel" class="input-select">
                            <% channels.forEach(channel => { %>
                                <option value="<%= channel.name %>" <%= config.welcome.channelName === channel.name ? 'selected' : '' %>>
                                    #<%= channel.name %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Welcome Message</label>
                        <textarea name="welcomeMessage" rows="3" class="input-field"><%= config.welcome.message %></textarea>
                        <small>Available placeholders: {user}, {server}, {memberCount}</small>
                    </div>

                    <div class="form-group">
                        <label>Embed Color</label>
                        <div class="color-picker-group">
                            <input type="color" name="welcomeColor" value="<%= config.welcome.embedColor %>" class="color-input">
                            <input type="text" id="colorText" value="<%= config.welcome.embedColor %>" class="input-field" style="width: 100px;">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Custom Welcome Card Background (URL)</label>
                        <input type="text" name="welcome_background" value="<%= settings.welcome_background || '' %>" class="input-field" placeholder="https://example.com/welcome-bg.png">
                        <small>Dimensions: 1024x450 recommended. Image will be resized.</small>
                    </div>
                </div>

                <!-- 2. Leave Settings -->
                <div class="settings-section">
                    <h2>Leave Configuration</h2>

                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" name="leaveEnabled" <%= config.leave.enabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            Enable Leave Messages
                        </label>
                    </div>

                    <div class="form-group">
                        <label>Leave Channel</label>
                        <select name="leaveChannel" class="input-select">
                            <% channels.forEach(channel => { %>
                                <option value="<%= channel.name %>" <%= config.leave.channelName === channel.name ? 'selected' : '' %>>
                                    #<%= channel.name %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Leave Message</label>
                        <textarea name="leaveMessage" rows="3" class="input-field"><%= config.leave.message %></textarea>
                        <small>Available placeholders: {user}, {server}, {memberCount}</small>
                    </div>
                </div>

                <div style="margin-top: 2rem;">
                    <button type="submit" class="btn btn-primary btn-large">Save All Welcome & Leave Settings</button>
                </div>
            </form>
        </div>
    </div>

    <div id="notification" class="notification"></div>

    <%- include('../partials/footer') %>

    <script>
        const guildId = '<%= guild.id %>';

        // Sync color input with text
        const colorInput = document.querySelector('input[name="welcomeColor"]');
        const colorText = document.getElementById('colorText');
        if (colorInput && colorText) {
            colorInput.addEventListener('input', () => colorText.value = colorInput.value.toUpperCase());
            colorText.addEventListener('input', () => colorInput.value = colorText.value);
        }

        document.getElementById('welcomeForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);

            const response = await fetch(`/api/server/${guildId}/welcome`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    welcomeEnabled: formData.get('welcomeEnabled') === 'on',
                    welcomeChannel: formData.get('welcomeChannel'),
                    welcomeMessage: formData.get('welcomeMessage'),
                    welcomeColor: formData.get('welcomeColor'),
                    auto_role: formData.get('auto_role'),
                    welcome_background: formData.get('welcome_background'),
                    leaveEnabled: formData.get('leaveEnabled') === 'on',
                    leaveChannel: formData.get('leaveChannel'),
                    leaveMessage: formData.get('leaveMessage')
                })
            });

            const data = await response.json();
            showNotification(data.message || 'Settings saved!', response.ok ? 'success' : 'error');
        });

        function showNotification(message, type) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification notification-${type} show`;
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    </script>
</body>
</html>
