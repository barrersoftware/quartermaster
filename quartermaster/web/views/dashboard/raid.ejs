<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raid Protection - <%= guild.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="dashboard-container">
        <div class="container">
            <div class="breadcrumb">
                <a href="/dashboard">Dashboard</a> /
                <a href="/dashboard/server/<%= guild.id %>"><%= guild.name %></a> /
                <span>Raid Protection</span>
            </div>

            <h1>🛡️ Raid Protection</h1>
            <p>Shield your server from automated raid attacks with intelligent join-rate monitoring.</p>

            <form id="raidForm">
                <!-- 1. General Settings -->
                <div class="settings-section">
                    <h2>Configuration</h2>

                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" name="enabled" <%= settings.enabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            Enable Raid Protection
                        </label>
                        <small>Automatically detect and respond to sudden bursts of new members joining.</small>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Join Threshold</label>
                            <input type="number" name="joinThreshold" value="<%= settings.join_threshold %>" min="2" max="50" class="input-field">
                            <small>Number of members joining to trigger detection.</small>
                        </div>
                        <div class="form-group">
                            <label>Time Window (seconds)</label>
                            <input type="number" name="timeWindow" value="<%= settings.time_window %>" min="5" max="300" class="input-field">
                            <small>The timeframe (in seconds) to count joins.</small>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Alert Channel</label>
                        <select name="alertChannel" class="input-select">
                            <option value="">Select a channel...</option>
                            <% channels.forEach(channel => { %>
                                <option value="<%= channel.name %>" <%= settings.alert_channel === channel.name ? 'selected' : '' %>>
                                    #<%= channel.name %>
                                </option>
                            <% }); %>
                        </select>
                        <small>Channel where the bot will post raid alerts and staff notifications.</small>
                    </div>
                </div>

                <!-- 2. Automated Response -->
                <div class="settings-section">
                    <h2>Automated Response</h2>

                    <div class="form-group">
                        <label>Action on Raid Detection</label>
                        <select name="action" class="input-select">
                            <option value="alert" <%= settings.action === 'alert' ? 'selected' : '' %>>Alert Only (No Action)</option>
                            <option value="kick" <%= settings.action === 'kick' ? 'selected' : '' %>>Kick Raiders</option>
                            <option value="ban" <%= settings.action === 'ban' ? 'selected' : '' %>>Ban Raiders</option>
                            <option value="lockdown" <%= settings.action === 'lockdown' ? 'selected' : '' %>>Server Lockdown</option>
                        </select>
                        <small>What Quartermaster should do automatically when a raid is confirmed.</small>
                    </div>

                    <div class="form-group">
                        <label>Lockdown Duration (seconds)</label>
                        <input type="number" name="lockdownDuration" value="<%= settings.lockdown_duration %>" min="60" max="3600" class="input-field">
                        <small>How long to keep the server in lockdown (kicking all new joins).</small>
                    </div>
                </div>

                <div style="margin-top: 2rem;">
                    <button type="submit" class="btn btn-primary btn-large">Save Raid Protection Settings</button>
                </div>
            </form>

            <!-- 3. Incident History -->
            <div class="settings-section">
                <h2>Recent Raid Incidents</h2>
                <% if (incidents.length === 0) { %>
                    <p class="muted">No raids detected yet. Your server is safe! 🎉</p>
                <% } else { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Joins</th>
                                <th>Action Taken</th>
                                <th>Affected</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% incidents.forEach(incident => {
                                const usersAffected = JSON.parse(incident.users_affected || '[]');
                            %>
                                <tr>
                                    <td><%= new Date(incident.detected_at * 1000).toLocaleString() %></td>
                                    <td><strong><%= incident.user_count %></strong></td>
                                    <td>
                                        <span class="badge <%= incident.action_taken === 'ban' ? 'badge-danger' : incident.action_taken === 'kick' ? 'badge-warning' : 'badge-info' %>">
                                            <%= incident.action_taken.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td><%= usersAffected.length %> users</td>
                                    <td>
                                        <% if (incident.resolved) { %>
                                            <span class="badge badge-success">Resolved</span>
                                        <% } else { %>
                                            <span class="badge badge-warning">Active</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>

            <!-- 4. Education -->
            <div class="settings-section">
                <h2>How it Works</h2>
                <div class="info-box">
                    <ul style="padding-left: 20px;">
                        <li><strong>Monitoring:</strong> Tracks all member joins in real-time.</li>
                        <li><strong>Detection:</strong> Triggers when the Join Threshold is hit within the Time Window.</li>
                        <li><strong>Alert:</strong> Instantly notifies staff in the Alert Channel.</li>
                        <li><strong>Lockdown:</strong> If enabled, the bot automatically kicks anyone who tries to join until the timer runs out.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div id="notification" class="notification"></div>

    <%- include('../partials/footer') %>

    <script>
        const guildId = '<%= guild.id %>';

        document.getElementById('raidForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);

            const response = await fetch(`/api/server/${guildId}/raid`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    enabled: formData.get('enabled') === 'on',
                    joinThreshold: formData.get('joinThreshold'),
                    timeWindow: formData.get('timeWindow'),
                    action: formData.get('action'),
                    alertChannel: formData.get('alertChannel'),
                    lockdownDuration: formData.get('lockdownDuration')
                })
            });

            const data = await response.json();
            showNotification(data.message || data.error, response.ok ? 'success' : 'error');
        });

        function showNotification(message, type) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification notification-${type} show`;
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    </script>
</body>
</html>
